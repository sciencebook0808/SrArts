// prisma/schema.prisma — Prisma 7 + CockroachDB (March 2026)
//
// VERIFIED RULES:
//  ✗ NO `url` in datasource — url lives exclusively in prisma.config.ts
//  ✓ provider = "prisma-client-js" (NOT "prisma-client") — required for
//    Next.js 16 + Turbopack. Wrong provider causes "cannot find .prisma/client/default"
//  ✓ CockroachDB Serverless/Dedicated with @prisma/adapter-pg
//  ✓ cuid() IDs — safe for distributed writes
//
// Docs: https://www.prisma.io/docs/guides/upgrade-prisma-orm/v7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
}

// ─── SOCIAL MEDIA ─────────────────────────────────────────────────────────────

enum SocialPlatform {
  INSTAGRAM
  YOUTUBE
  TWITTER
  FACEBOOK
}

/// Social media account stats for the artist profile.
/// Fetch priority: Clerk OAuth → Official/RapidAPI → Manual.
/// Cron runs daily 5 PM IST (11:30 UTC). Manual fields never overwritten by cron.
model SocialAccount {
  id        String         @id @default(cuid())
  profileId String         @default("artist_profile")
  platform  SocialPlatform
  username  String

  // ── API-fetched stats (cron-populated) ──────────────────────────────────
  followers   Int?
  posts       Int?
  avatarUrl   String?
  displayName String?

  // ── Manual override (admin-set, NEVER touched by cron) ─────────────────
  manualFollowers Int?
  manualPosts     Int?
  useManual       Boolean @default(false)

  // ── Clerk OAuth integration ─────────────────────────────────────────────
  // When the admin connects their social account via Clerk OAuth, we store:
  //   clerkUserId   — admin's Clerk user ID (used to retrieve access token)
  //   clerkProvider — Clerk OAuth provider string (e.g. "oauth_facebook")
  //   oauthConnected — true once verified and working
  clerkUserId    String?
  clerkProvider  String?  // "oauth_google" | "oauth_facebook" | "oauth_twitter"
  oauthConnected Boolean  @default(false)

  // ── Fetch tracking (shown in admin dashboard metrics panel) ────────────
  lastFetchMethod String?  // "clerk_oauth" | "youtube_api" | "rapidapi" | "manual" | null
  lastFetchError  String?  // Last error message, null on success
  fetchStatus     String   @default("pending") // "pending"|"success"|"failed"|"manual"

  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([profileId, platform, username])
  @@index([profileId])
  @@index([platform])
  @@index([fetchStatus])
}

// ─── ARTWORKS ────────────────────────────────────────────────────────────────

model Artwork {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String?
  category      String?
  categoryId    String?
  imageUrl      String   @default("")
  imageId       String?
  price         Float?
  featured      Boolean  @default(false)
  views         Int      @default(0)
  likes         Int      @default(0)
  order         Int      @default(0)
  status        String   @default("draft")
  instagramLink String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  artworkLikes ArtworkLike[]
  comments     Comment[]

  @@index([status])
  @@index([slug])
  @@index([featured, status])
}

// ─── BLOG POSTS ──────────────────────────────────────────────────────────────

model BlogPost {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  content        String
  excerpt        String?
  coverImage     String?
  coverImageId   String?
  author         String   @default("SR Arts")
  category       String?
  tags           String[]
  status         String   @default("draft")
  views          Int      @default(0)
  featured       Boolean  @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comments Comment[]

  @@index([status])
  @@index([slug])
  @@index([featured, status])
}

// ─── CATEGORIES ──────────────────────────────────────────────────────────────

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  order Int    @default(0)

  @@index([order])
}

// ─── COMMISSIONS ─────────────────────────────────────────────────────────────

model Commission {
  id           String   @id @default(cuid())
  userName     String
  userEmail    String
  userPhone    String?
  projectTitle String?
  description  String?
  style        String?
  budget       String?
  timeline     String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([status])
}

// ─── ARTIST PROFILE (singleton — id = "artist_profile") ─────────────────────

model Profile {
  id              String   @id @default("artist_profile")
  name            String?
  headline        String?
  bio             String?
  location        String?
  profileImage    String?
  profileImageId  String?
  bannerImage     String?
  bannerImageId   String?
  instagram       String?
  twitter         String?
  email           String?
  website         String?
  skills          String[]
  yearsExperience Int?
  artworksCount   String?
  clientsCount    String?
  followersCount  String?
  experience      Json     @default("[]")
  achievements    Json     @default("[]")
  updatedAt       DateTime @default(now()) @updatedAt
}

// ─── ARTWORK LIKES ────────────────────────────────────────────────────────────

model ArtworkLike {
  id        String   @id @default(cuid())
  artworkId String
  userId    String
  createdAt DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([artworkId, userId])
  @@index([artworkId])
  @@index([userId])
}

// ─── COMMENTS (polymorphic + hierarchical) ───────────────────────────────────
//
// DESIGN: Adjacency-list threading (parentId → Comment.id).
//  • parentId = null  → top-level comment
//  • parentId = <id>  → reply to that comment
//  • replyTo fields   → @mention metadata (set when replying to a nested reply)
//  • replyCount       → denormalised child count (avoid COUNT(*) on reads)
//  • isDeleted        → soft-delete; preserves thread tree, shows "[deleted]"
//  • editedAt         → non-null signals an edit occurred
//
// FK RELATIONS:
//  artworkId / blogPostId / communityPostId each create a real FK so that
//  ON DELETE CASCADE removes comments when their parent record is deleted.
//
// INDEXES optimised for:
//  • Feed query:        (targetId, targetType, parentId, createdAt)
//  • Author management: (userId)
//  • Reply lookup:      (parentId)

model Comment {
  id         String    @id @default(cuid())
  targetId   String
  targetType String    // "artwork" | "blog" | "community"

  // Author info (denormalised from Clerk at creation time — never updated)
  userId    String
  username  String
  userImage String?

  // Content
  message   String
  isDeleted Boolean   @default(false)
  editedAt  DateTime?

  // Threading
  parentId  String?   // null = top-level comment
  replyCount Int      @default(0)

  // @mention tracking — the specific user this reply is directed at
  replyToUserId   String?
  replyToUsername String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // ── FK relations — enables proper ON DELETE CASCADE ──────────────────────
  artwork         Artwork?       @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  artworkId       String?
  blogPost        BlogPost?      @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogPostId      String?
  communityPost   CommunityPost? @relation(fields: [communityPostId], references: [id], onDelete: Cascade)
  communityPostId String?

  // ── Self-referential threading ───────────────────────────────────────────
  // SetNull on parent delete: replies survive but become "orphaned" top-level
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([targetId, targetType, parentId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@index([communityPostId])
}

// ─── COMMUNITY POSTS ─────────────────────────────────────────────────────────

model CommunityPost {
  id             String   @id @default(cuid())
  slug           String?  @unique
  authorId       String
  authorName     String
  authorImage    String?
  content        String
  imageUrl       String?
  imageId        String?
  repostOfId     String?
  repostNote     String?
  referenceType  String?
  referenceId    String?
  referenceTitle String?
  referenceImage String?
  referenceSlug  String?
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  repostsCount   Int      @default(0)
  shareCount     Int      @default(0)
  status         String   @default("published")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  postLikes CommunityLike[]
  repostOf  CommunityPost?  @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts   CommunityPost[] @relation("Reposts")
  comments  Comment[]

  @@index([authorId])
  @@index([status, createdAt])
  @@index([slug])
  @@index([referenceType, referenceId])
}

// ─── COMMUNITY LIKES ─────────────────────────────────────────────────────────

model CommunityLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ─── STATIC PAGES ────────────────────────────────────────────────────────────

model StaticPage {
  id        String   @id
  title     String
  content   String   @default("")
  updatedAt DateTime @default(now()) @updatedAt

  @@index([id])
}

// ─── SITE NOTIFICATIONS (admin-created banner alerts) ─────────────────────────
//
// The admin creates a notification with a message and optional type.
// The banner appears above the navbar on all public pages.
// Only one notification is shown at a time (the most recent active one).
// Users dismiss it client-side via localStorage (keyed by notification id).

model SiteNotification {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("info") // "info" | "warning" | "success" | "error"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, createdAt])
}
