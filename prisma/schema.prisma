// prisma/schema.prisma
//
// ── Prisma 7 Rules (March 2026) ───────────────────────────────────────────────
//  ✗ NO `url` in datasource — url lives exclusively in prisma.config.ts
//  ✓ provider = "cockroachdb" for CockroachDB Serverless / Dedicated
//  ✓ No previewFeatures needed for driverAdapters in Prisma 7 GA
//  ✓ IDs: cuid() — safe for distributed writes, no sequential hot-spots
//  ✓ All relation onDelete actions explicitly set
//
// Docs: prisma.io/docs/orm/more/upgrade-guides/upgrading-versions/upgrading-to-prisma-7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  // NO url here — Prisma 7 requires url in prisma.config.ts ONLY
}

// ─────────────────────────────────────────────────────────────────────────────
// ARTWORKS
// ─────────────────────────────────────────────────────────────────────────────

model Artwork {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String?
  category      String?
  categoryId    String?
  imageUrl      String   @default("")
  imageId       String?
  price         Float?
  featured      Boolean  @default(false)
  views         Int      @default(0)
  likes         Int      @default(0)
  order         Int      @default(0)
  status        String   @default("draft")
  instagramLink String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  artworkLikes  ArtworkLike[]
  comments      Comment[]

  @@index([status])
  @@index([slug])
  @@index([featured, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG POSTS
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  content        String
  excerpt        String?
  coverImage     String?
  coverImageId   String?
  author         String   @default("SR Arts")
  category       String?
  tags           String[]
  status         String   @default("draft")
  views          Int      @default(0)
  featured       Boolean  @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comments       Comment[]

  @@index([status])
  @@index([slug])
  @@index([featured, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  order Int    @default(0)

  @@index([order])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMISSIONS
// ─────────────────────────────────────────────────────────────────────────────

model Commission {
  id           String   @id @default(cuid())
  userName     String
  userEmail    String
  userPhone    String?
  projectTitle String?
  description  String?
  style        String?
  budget       String?
  timeline     String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// ARTIST PROFILE (singleton — id = "artist_profile")
// ─────────────────────────────────────────────────────────────────────────────

model Profile {
  id              String   @id @default("artist_profile")
  name            String?
  headline        String?
  bio             String?
  location        String?
  profileImage    String?
  profileImageId  String?
  bannerImage     String?
  bannerImageId   String?
  instagram       String?
  twitter         String?
  email           String?
  website         String?
  skills          String[]
  yearsExperience Int?
  artworksCount   String?
  clientsCount    String?
  followersCount  String?
  // Structured experience + achievements — stored as JSON arrays
  // [{ id, year, title, role, description }]
  experience      Json     @default("[]")
  // [{ id, year, title, description }]
  achievements    Json     @default("[]")
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// ARTWORK LIKES — Clerk auth required
// ─────────────────────────────────────────────────────────────────────────────

model ArtworkLike {
  id        String   @id @default(cuid())
  artworkId String
  userId    String   // Clerk user ID — required (not anonymous)
  createdAt DateTime @default(now())

  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([artworkId, userId])
  @@index([artworkId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMENTS (polymorphic: artwork | blog | community)
// ─────────────────────────────────────────────────────────────────────────────

model Comment {
  id         String    @id @default(cuid())
  targetId   String
  targetType String    // "artwork" | "blog" | "community"
  userId     String
  username   String
  userImage  String?
  message    String
  createdAt  DateTime  @default(now())

  artwork    Artwork?  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  artworkId  String?
  blogPost   BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogPostId String?

  @@index([targetId, targetType])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNITY POSTS (LinkedIn-style feed)
// ─────────────────────────────────────────────────────────────────────────────

model CommunityPost {
  id             String    @id @default(cuid())
  slug           String?   @unique
  authorId       String
  authorName     String
  authorImage    String?
  content        String
  imageUrl       String?
  imageId        String?
  // Community-post-to-community-post repost FK (cascade-safe)
  repostOfId     String?
  repostNote     String?
  // Universal reference system — supports artwork | blog | post reposts
  referenceType  String?   // 'post' | 'artwork' | 'blog'
  referenceId    String?   // ID of the referenced content
  referenceTitle String?   // Cached title for display (artwork title / blog title)
  referenceImage String?   // Cached image URL for display
  referenceSlug  String?   // Cached slug for link navigation
  likesCount     Int       @default(0)
  commentsCount  Int       @default(0)
  repostsCount   Int       @default(0)
  shareCount     Int       @default(0)
  status         String    @default("published")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  postLikes      CommunityLike[]
  repostOf       CommunityPost?  @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts        CommunityPost[] @relation("Reposts")

  @@index([authorId])
  @@index([status, createdAt])
  @@index([slug])
  @@index([referenceType, referenceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNITY LIKES — Clerk auth required
// ─────────────────────────────────────────────────────────────────────────────

model CommunityLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// STATIC PAGES — singleton rows (id = "terms" | "privacy")
// ─────────────────────────────────────────────────────────────────────────────

model StaticPage {
  id        String   @id   // fixed: "terms" | "privacy"
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@index([id])
}
