// prisma/schema.prisma — Prisma 7 + CockroachDB (March 2026)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id              String   @id @default("artist_profile")
  name            String?
  headline        String?
  bio             String?
  location        String?
  profileImage    String?
  profileImageId  String?
  bannerImage     String?
  bannerImageId   String?
  instagram       String?
  twitter         String?
  email           String?
  website         String?
  skills          String[]
  yearsExperience Int?
  artworksCount   String?
  clientsCount    String?
  followersCount  String?
  experience      Json     @default("[]")
  achievements    Json     @default("[]")
  updatedAt       DateTime @updatedAt
}

model Artwork {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?
  imageUrl     String?
  imageId      String?
  category     String?
  tags         String[]
  status       String   @default("published")
  featured     Boolean  @default(false)
  order        Int      @default(0)
  price        Float?
  currency     String?  @default("USD")
  sold         Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  likes        ArtworkLike[]
  comments     Comment[] @relation("ArtworkComments")
  @@index([status])
  @@index([featured])
  @@index([category])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model BlogPost {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  excerpt      String?
  content      String
  coverImage   String?
  coverImageId String?
  category     String?
  tags         String[]
  published    Boolean  @default(false)
  featured     Boolean  @default(false)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  comments     Comment[] @relation("BlogComments")
  @@index([published])
  @@index([featured])
}

model Commission {
  id          String   @id @default(cuid())
  name        String
  email       String
  description String
  budget      String?
  timeline    String?
  status      String   @default("pending")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([status])
}

model ArtworkLike {
  id        String   @id @default(cuid())
  artworkId String
  userId    String
  createdAt DateTime @default(now())
  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  @@unique([artworkId, userId])
  @@index([artworkId])
  @@index([userId])
}

model Comment {
  id         String    @id @default(cuid())
  targetId   String
  targetType String
  userId     String?
  username   String
  userImage  String?
  message    String
  createdAt  DateTime  @default(now())
  artwork    Artwork?  @relation("ArtworkComments", fields: [artworkId], references: [id], onDelete: Cascade)
  artworkId  String?
  blogPost   BlogPost? @relation("BlogComments", fields: [blogPostId], references: [id], onDelete: Cascade)
  blogPostId String?
  @@index([targetId, targetType])
}

model CommunityPost {
  id            String    @id @default(cuid())
  slug          String?   @unique
  authorId      String
  authorName    String
  authorImage   String?
  content       String
  imageUrl      String?
  imageId       String?
  likesCount    Int       @default(0)
  repostsCount  Int       @default(0)
  commentsCount Int       @default(0)
  shareCount    Int       @default(0)
  repostOfId    String?
  repostNote    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  repostOf      CommunityPost?  @relation("Reposts", fields: [repostOfId], references: [id])
  reposts       CommunityPost[] @relation("Reposts")
  likes         CommunityLike[]
  @@index([authorId])
  @@index([createdAt])
  @@index([slug])
}

model CommunityLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model StaticPage {
  id        String   @id
  slug      String   @unique
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  @@index([slug])
}
